# Database — matches docker-compose.yml defaults; override for managed/remote DB
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hunch?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# LLM — Claude routed via OpenRouter (Mastra `openrouter/...` model router)
OPENROUTER_API_KEY="sk-or-v1-..."
